<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="12.0" left="14.0" right="14.0" top="12.0" />
    </padding>

    <Label text="Modul Service / Teknisi" textFill="#1e293b">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <HBox spacing="15.0">
        <!-- Input Form -->
        <VBox spacing="10.0" style="-fx-background-color: #f9f9f9; -fx-padding: 15; -fx-background-radius: 5;" prefWidth="350.0">
            <Label text="Input Servis Baru" style="-fx-font-weight: bold;" />
            
            <Label text="Nama Pelanggan / No. HP:" />
            <TextField promptText="Nama Customer" />
            
            <Label text="Device / Perangkat:" />
            <TextField promptText="Cth: ASUS X441U" />
            
            <Label text="Keluhan / Kerusakan:" />
            <TextArea prefHeight="80.0" promptText="Deskripsi masalah..." />
            
            <Label text="Perkiraan Biaya:" />
            <TextField promptText="Rp 0" />
            
            <Button text="Terima Servis" styleClass="primary-button" maxWidth="Infinity">
                 <VBox.margin>
                    <Insets top="10.0" />
                 </VBox.margin>
            </Button>
        </VBox>

        <!-- List Service -->
        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <Label text="Antrian Service" style="-fx-font-weight: bold;" />
            <TableView VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn text="No. Ticket" prefWidth="100.0" />
                    <TableColumn text="Tanggal" prefWidth="100.0" />
                    <TableColumn text="Pelanggan" prefWidth="150.0" />
                    <TableColumn text="Device" prefWidth="150.0" />
                    <TableColumn text="Status" prefWidth="100.0" />
                    <TableColumn text="Teknisi" prefWidth="100.0" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
            
            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <Button text="Update Status" />
                <Button text="Selesai &amp; Bayar" style="-fx-base: #1E40AF;" />
            </HBox>
        </VBox>
    </HBox>
</VBox>



