<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.baletpos.controller.LoginController"
           style="-fx-background-color: #eef2f6;">

    <HBox maxWidth="820" maxHeight="500" styleClass="panel">
        <VBox prefWidth="330" spacing="18" alignment="CENTER_LEFT"
              style="-fx-background-color: #17212f; -fx-background-radius: 8 0 0 8; -fx-padding: 34;">
            <ImageView fitHeight="52" preserveRatio="true">
                <Image url="@../images/logo.png"/>
            </ImageView>
            <VBox spacing="6">
                <Label text="BALET COMPUTER" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: white;"/>
                <Label text="Point of Sale" style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #b6c2d1;"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox spacing="8">
                <Label text="Kasir dan admin dalam satu sistem." wrapText="true"
                       style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #ffffff;"/>
                <Label text="Masuk sesuai akun untuk membuka menu operasional toko." wrapText="true"
                       style="-fx-font-size: 12px; -fx-text-fill: #b6c2d1;"/>
            </VBox>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="20" prefWidth="490"
              style="-fx-background-color: white; -fx-background-radius: 0 8 8 0; -fx-padding: 42 46;">
            <VBox spacing="4">
                <Label text="Masuk" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #111827;"/>
                <Label text="Gunakan akun kasir atau admin yang sudah dibuat." style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
            </VBox>

            <VBox spacing="14" maxWidth="Infinity">
                <VBox spacing="6">
                    <Label text="Username" style="-fx-font-weight: 800; -fx-text-fill: #334155; -fx-font-size: 12px;"/>
                    <TextField fx:id="usernameField" promptText="contoh: admin" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Password" style="-fx-font-weight: 800; -fx-text-fill: #334155; -fx-font-size: 12px;"/>
                    <PasswordField fx:id="passwordField" promptText="Masukkan password" maxWidth="Infinity"
                                   onAction="#handleLogin"/>
                </VBox>

                <Label fx:id="errorLabel" visible="false" managed="false"
                       style="-fx-background-color: #fee2e2; -fx-text-fill: #991b1b; -fx-padding: 9 10; -fx-background-radius: 6; -fx-font-size: 12px; -fx-font-weight: 700;"
                       wrapText="true" maxWidth="Infinity"/>

                <Button fx:id="loginButton" text="Masuk" onAction="#handleLogin" maxWidth="Infinity"
                        minHeight="40" styleClass="primary-button"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            <Label text="BaletPOS v1.0" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
        </VBox>
    </HBox>
</StackPane>
