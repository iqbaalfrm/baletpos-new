<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.baletpos.controller.ExpenseController"
      style="-fx-background-color: #f8fafc; -fx-padding: 14;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <VBox spacing="4">
            <Label text="Biaya Operasional" style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #0f172a;"/>
            <Label text="Catat dan kelola pengeluaran operasional toko" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
        </VBox>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="⚙ Kelola Kode Biaya" onAction="#handleManageCodes" 
                style="-fx-background-color: white; -fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 12 20; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e2e8f0; -fx-border-width: 1.5; -fx-cursor: hand;"/>
    </HBox>

    <!-- Filters Card -->
    <HBox spacing="10" alignment="CENTER_LEFT" 
          style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-padding: 14;">
        <VBox spacing="8">
            <Label text="Periode" style="-fx-font-size: 12px; -fx-font-weight: 600; -fx-text-fill: #64748b;"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <DatePicker fx:id="startDatePicker" prefWidth="150"
                            style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                <Label text="sampai" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                <DatePicker fx:id="endDatePicker" prefWidth="150"
                            style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>
            </HBox>
        </VBox>
        <Separator orientation="VERTICAL" style="-fx-padding: 0 8;"/>
        <VBox spacing="8">
            <Label text="Kode Biaya" style="-fx-font-size: 12px; -fx-font-weight: 600; -fx-text-fill: #64748b;"/>
            <ComboBox fx:id="expenseCodeCombo" promptText="Semua Kode" prefWidth="220"
                      style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox spacing="8">
            <Label text=" " style="-fx-font-size: 12px;"/>
            <Button text="↻ Filter" onAction="#handleRefresh" 
                    style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 20; -fx-background-radius: 8; -fx-border-radius: 8; -fx-cursor: hand;"/>
        </VBox>
    </HBox>

    <!-- Action Buttons -->
    <HBox spacing="12">
        <Button fx:id="addButton" text="+ Tambah Biaya" onAction="#handleAdd" 
                style="-fx-background-color: linear-gradient(to bottom, #dc2626, #b91c1c); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 12 24; -fx-background-radius: 10; -fx-border-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(220, 38, 38, 0.3), 6, 0, 0, 2);"/>
        <Button fx:id="deleteButton" text="🗑 Hapus" onAction="#handleDelete" disable="true"
                style="-fx-background-color: rgba(239, 68, 68, 0.1); -fx-text-fill: #dc2626; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 12 20; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: rgba(239, 68, 68, 0.3); -fx-border-width: 1.5; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <!-- Total Badge -->
        <HBox alignment="CENTER" spacing="8" 
              style="-fx-background-color: linear-gradient(to right, rgba(239, 68, 68, 0.1), rgba(239, 68, 68, 0.15)); -fx-padding: 12 24; -fx-background-radius: 12; -fx-border-color: rgba(239, 68, 68, 0.2); -fx-border-radius: 12; -fx-border-width: 1;">
            <Label text="Total Pengeluaran:" style="-fx-font-size: 13px; -fx-text-fill: #b91c1c; -fx-font-weight: 600;"/>
            <Label fx:id="totalLabel" text="Rp 0" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #dc2626;"/>
        </HBox>
    </HBox>

    <!-- Table -->
    <VBox fx:id="tableContainer" VBox.vgrow="ALWAYS" 
          style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);">
        <TableView fx:id="expenseTable" VBox.vgrow="ALWAYS" 
                   style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <columns>
                <TableColumn fx:id="numberCol" text="NO. BIAYA" prefWidth="140"/>
                <TableColumn fx:id="dateCol" text="TANGGAL" prefWidth="110"/>
                <TableColumn fx:id="codeCol" text="KODE" prefWidth="90"/>
                <TableColumn fx:id="codeNameCol" text="NAMA BIAYA" prefWidth="160"/>
                <TableColumn fx:id="amountCol" text="NOMINAL" prefWidth="160"/>
                <TableColumn fx:id="descriptionCol" text="KETERANGAN" prefWidth="220"/>
            </columns>
            <placeholder>
                <VBox alignment="CENTER" spacing="12" style="-fx-padding: 48;">
                    <Label text="💰" style="-fx-font-size: 48px;"/>
                    <Label text="Belum ada data biaya" style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #64748b;"/>
                    <Label text="Klik tombol 'Tambah Biaya' untuk mencatat pengeluaran" style="-fx-font-size: 13px; -fx-text-fill: #94a3b8;"/>
                </VBox>
            </placeholder>
        </TableView>
    </VBox>
</VBox>



