<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.baletpos.controller.DashboardController"
            styleClass="dashboard-shell">

    <top>
        <HBox fx:id="topBar" alignment="CENTER_LEFT" spacing="16" styleClass="dashboard-topbar">
            <Label fx:id="welcomeLabel" text="Dashboard" styleClass="dashboard-title"/>
            <TextField promptText="Cari transaksi atau produk..." HBox.hgrow="ALWAYS" maxWidth="420" styleClass="dashboard-search"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="SYNC" styleClass="sync-button"/>
            <Button text="KASIR" onAction="#showPOS" styleClass="primary-button"/>
            <Separator orientation="VERTICAL"/>
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label text="Admin Toko" styleClass="user-name"/>
                <Label fx:id="roleLabel" text="ADMIN_TOKO" styleClass="user-role"/>
            </VBox>
            <Button text="Keluar" onAction="#handleLogout" styleClass="danger-button"/>
        </HBox>
    </top>

    <left>
        <VBox fx:id="sidebar" styleClass="sidebar dashboard-sidebar">
            <padding><Insets top="24" bottom="14"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="logo-block">
                <StackPane styleClass="logo-mark">
                    <Label text="BP" styleClass="logo-mark-text"/>
                </StackPane>
                <VBox spacing="1">
                    <Label text="BaletPOS" styleClass="logo-title"/>
                    <Label text="Hardware Solutions" styleClass="logo-subtitle"/>
                </VBox>
            </HBox>

            <VBox spacing="2" styleClass="nav-list">
                <Button text="Dashboard" onAction="#showDashboard" maxWidth="Infinity" alignment="BASELINE_LEFT"
                        styleClass="nav-button active"/>
                <Button text="POS / Kasir" onAction="#showPOS" maxWidth="Infinity" alignment="BASELINE_LEFT"
                        styleClass="nav-button"/>
                <Button text="Produk" onAction="#showProducts" maxWidth="Infinity" alignment="BASELINE_LEFT"
                        styleClass="nav-button"/>
                <Button fx:id="purchaseButton" text="Pembelian" onAction="#showPurchase" maxWidth="Infinity" alignment="BASELINE_LEFT"
                        styleClass="nav-button"/>
                <Button fx:id="supplierButton" text="Supplier" onAction="#showSuppliers" maxWidth="Infinity" alignment="BASELINE_LEFT"
                        styleClass="nav-button"/>
                <Button fx:id="returnButton" text="Retur / Mutasi" onAction="#showReturns" maxWidth="Infinity" alignment="BASELINE_LEFT"
                        styleClass="nav-button"/>
                <Button fx:id="expenseButton" text="Biaya" onAction="#showExpenses" maxWidth="Infinity" alignment="BASELINE_LEFT"
                        styleClass="nav-button"/>
                <Button text="Penjualan" onAction="#showSalesReportLaptop" maxWidth="Infinity" alignment="BASELINE_LEFT"
                        styleClass="nav-button"/>
                <Button text="Transaksi" onAction="#showTransactionList" maxWidth="Infinity" alignment="BASELINE_LEFT"
                        styleClass="nav-button"/>
                <Button text="Aset / Inventory" onAction="#showInventoryReport" maxWidth="Infinity" alignment="BASELINE_LEFT"
                        styleClass="nav-button"/>
                <Button fx:id="profitLossButton" text="Laba Rugi" onAction="#showProfitLossReport" maxWidth="Infinity" alignment="BASELINE_LEFT"
                        styleClass="nav-button"/>
            </VBox>

            <VBox VBox.vgrow="ALWAYS"/>

            <VBox spacing="2" styleClass="nav-list nav-system">
                <Button fx:id="settingsButton" text="Setting" onAction="#showSettings" maxWidth="Infinity" alignment="BASELINE_LEFT"
                        styleClass="nav-button"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="dashboard-content-host"/>
    </center>

</BorderPane>
