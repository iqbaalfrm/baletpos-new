<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.baletpos.controller.DashboardContentController"
            fitToWidth="true" hbarPolicy="NEVER" styleClass="dashboard-scroll">

    <VBox spacing="20" styleClass="dashboard-canvas">
        <padding>
            <Insets top="24" right="24" bottom="24" left="24"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="3">
                <Label text="Ringkasan Operasional" styleClass="panel-title"/>
                <Label text="Data dashboard mengikuti database aktif desktop." styleClass="muted-label"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="dbStatusLabel" text="DB: Mengecek..." styleClass="db-status"/>
        </HBox>

        <HBox spacing="16" styleClass="kpi-row">
            <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="kpi-card">
                <Label text="Penjualan Hari Ini" styleClass="kpi-label"/>
                <HBox alignment="BOTTOM_LEFT" spacing="10">
                    <Label fx:id="todayTransactionLabel" text="0" styleClass="kpi-value"/>
                    <Label fx:id="transactionTrendLabel" text="0% vs Kemarin" styleClass="trend-good"/>
                </HBox>
                <ProgressBar progress="0.75" maxWidth="Infinity" styleClass="kpi-progress"/>
            </VBox>

            <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="kpi-card">
                <Label text="Omzet Hari Ini" styleClass="kpi-label"/>
                <Label fx:id="todaySalesLabel" text="Rp 0" styleClass="kpi-value kpi-money"/>
                <Label fx:id="salesTrendLabel" text="0% vs Kemarin" styleClass="muted-label"/>
            </VBox>

            <HBox spacing="12" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" styleClass="kpi-card">
                <StackPane styleClass="metric-icon danger-metric">
                    <Label text="!" styleClass="metric-icon-text"/>
                </StackPane>
                <VBox spacing="5">
                    <Label text="Stok Menipis" styleClass="kpi-label"/>
                    <Label fx:id="lowStockTotalLabel" text="0 item" styleClass="kpi-value danger-text"/>
                    <Label text="Item perlu restock" styleClass="muted-label"/>
                </VBox>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" styleClass="kpi-card">
                <StackPane styleClass="metric-icon sync-metric">
                    <Label text="S" styleClass="metric-icon-text"/>
                </StackPane>
                <VBox spacing="5">
                    <Label text="Pengeluaran Bulan Ini" styleClass="kpi-label"/>
                    <Label fx:id="monthExpenseLabel" text="Rp 0" styleClass="kpi-value warning-text"/>
                    <Label fx:id="expenseTrendLabel" text="0% vs Bulan Lalu" styleClass="muted-label"/>
                </VBox>
            </HBox>
        </HBox>

        <GridPane hgap="20" vgap="20">
            <columnConstraints>
                <ColumnConstraints percentWidth="66"/>
                <ColumnConstraints percentWidth="34"/>
            </columnConstraints>

            <VBox spacing="14" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="panel dashboard-panel">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="3">
                        <Label text="Sales Trend (Weekly)" styleClass="panel-title"/>
                        <Label fx:id="chartSummaryLabel" text="Total: Rp 0" styleClass="muted-label"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="growthBadge" text="0% Pertumbuhan" styleClass="blue-badge"/>
                </HBox>
                <LineChart fx:id="salesTrendChart" minHeight="260" prefHeight="280" legendVisible="false"
                           animated="false" createSymbols="false" horizontalGridLinesVisible="true"
                           verticalGridLinesVisible="false">
                    <xAxis>
                        <CategoryAxis fx:id="chartXAxis" side="BOTTOM"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis fx:id="chartYAxis" side="LEFT" label="Juta Rp"/>
                    </yAxis>
                </LineChart>
            </VBox>

            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="panel table-panel">
                <HBox alignment="CENTER_LEFT" styleClass="panel-header">
                    <Label text="Top Products" styleClass="panel-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="..." styleClass="panel-action"/>
                </HBox>
                <VBox fx:id="topProductsContainer" spacing="0">
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="list-row">
                        <VBox HBox.hgrow="ALWAYS" spacing="2">
                            <Label fx:id="topProduct1Name" text="Memuat..." styleClass="row-title"/>
                            <Label fx:id="topProduct1Sku" text="SKU: -" styleClass="row-subtitle"/>
                        </VBox>
                        <Label fx:id="topProduct1Qty" text="0 Terjual" styleClass="row-value"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="list-row">
                        <VBox HBox.hgrow="ALWAYS" spacing="2">
                            <Label fx:id="topProduct2Name" text="Memuat..." styleClass="row-title"/>
                            <Label fx:id="topProduct2Sku" text="SKU: -" styleClass="row-subtitle"/>
                        </VBox>
                        <Label fx:id="topProduct2Qty" text="0 Terjual" styleClass="row-value"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="list-row">
                        <VBox HBox.hgrow="ALWAYS" spacing="2">
                            <Label fx:id="topProduct3Name" text="Memuat..." styleClass="row-title"/>
                            <Label fx:id="topProduct3Sku" text="SKU: -" styleClass="row-subtitle"/>
                        </VBox>
                        <Label fx:id="topProduct3Qty" text="0 Terjual" styleClass="row-value"/>
                    </HBox>
                </VBox>
            </VBox>

            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="panel table-panel">
                <HBox alignment="CENTER_LEFT" styleClass="panel-header">
                    <Label text="Latest Transactions" styleClass="panel-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Lihat Semua" styleClass="link-button"/>
                </HBox>
                <VBox fx:id="latestTransactionsContainer" styleClass="mini-table"/>
            </VBox>

            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="panel table-panel">
                <HBox alignment="CENTER_LEFT" styleClass="panel-header">
                    <Label text="Low Stock" styleClass="panel-title danger-text"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="INV" styleClass="danger-text"/>
                </HBox>
                <VBox fx:id="lowStockContainer" spacing="0">
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="list-row">
                        <VBox HBox.hgrow="ALWAYS" spacing="2">
                            <Label fx:id="lowStock1Name" text="Memuat..." styleClass="row-title"/>
                            <Label fx:id="lowStock1Qty" text="Sisa 0 unit" styleClass="row-value danger-text"/>
                        </VBox>
                        <Button fx:id="restock1Btn" text="Restok" styleClass="link-button"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="list-row">
                        <VBox HBox.hgrow="ALWAYS" spacing="2">
                            <Label fx:id="lowStock2Name" text="Memuat..." styleClass="row-title"/>
                            <Label fx:id="lowStock2Qty" text="Sisa 0 unit" styleClass="row-value danger-text"/>
                        </VBox>
                        <Button fx:id="restock2Btn" text="Restok" styleClass="link-button"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="list-row">
                        <VBox HBox.hgrow="ALWAYS" spacing="2">
                            <Label fx:id="lowStock3Name" text="Memuat..." styleClass="row-title"/>
                            <Label fx:id="lowStock3Qty" text="Sisa 0 unit" styleClass="row-value danger-text"/>
                        </VBox>
                        <Button fx:id="restock3Btn" text="Restok" styleClass="link-button"/>
                    </HBox>
                </VBox>
                <Button text="BUAT PESANAN STOK" maxWidth="Infinity" styleClass="danger-button"/>
            </VBox>
        </GridPane>
    </VBox>
</ScrollPane>
