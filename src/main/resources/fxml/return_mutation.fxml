<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.baletpos.controller.ReturnMutationController" spacing="16"
      style="-fx-background-color: #f8fafc; -fx-padding: 14;">
      
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Retur &amp; Mutasi Stok" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" fx:id="mainTabPane" style="-fx-background-color: transparent;">
        
        <!-- HISTORY TAB -->
        <Tab text="Riwayat">
            <VBox spacing="16" style="-fx-padding: 16 0 0 0;">
             <!-- Sub Tabs -->
             <TabPane tabClosingPolicy="UNAVAILABLE" fx:id="historyTabPane" VBox.vgrow="ALWAYS">
               <Tab text="Riwayat Retur">
                  <VBox spacing="12" style="-fx-padding: 12 0 0 0;">
                      <HBox spacing="10" alignment="CENTER_LEFT">
                          <Button text="Refresh" onAction="#handleRefreshReturns" styleClass="secondary-button"/>
                          <Region HBox.hgrow="ALWAYS"/>
                          <Label text="Cari"/>
                          <TextField fx:id="searchReturnField" promptText="No retur / invoice / user" prefWidth="220"/>
                          <Button text="Export PDF" onAction="#handleExportReturnPdf" styleClass="danger-button"/>
                          <Button text="Export Excel" onAction="#handleExportReturnExcel" styleClass="success-button"/>
                      </HBox>
                      <VBox fx:id="returnHistoryContainer" VBox.vgrow="ALWAYS" spacing="0">
                          <TableView fx:id="tableReturnHistory" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                             <columns>
                                 <TableColumn fx:id="colReturnNo" text="No. Retur" prefWidth="140"/>
                                 <TableColumn fx:id="colReturnInvoice" text="Invoice Asal" prefWidth="140"/>
                                 <TableColumn fx:id="colReturnDate" text="Tanggal" prefWidth="140"/>
                                 <TableColumn fx:id="colReturnTotal" text="Total Retur" prefWidth="120"/>
                                 <TableColumn fx:id="colReturnUser" text="Oleh" prefWidth="100"/>
                                 <TableColumn fx:id="colReturnAction" text="Aksi" prefWidth="90"/>
                             </columns>
                             <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                             <placeholder>
                                 <Label text="Tidak ada data"/>
                             </placeholder>
                          </TableView>
                      </VBox>
                  </VBox>
               </Tab>
               <Tab text="Riwayat Mutasi">
                  <VBox spacing="12" style="-fx-padding: 12 0 0 0;">
                      <HBox spacing="10" alignment="CENTER_LEFT">
                          <Button text="Refresh" onAction="#handleRefreshAdjustments" styleClass="secondary-button"/>
                          <Region HBox.hgrow="ALWAYS"/>
                          <Label text="Cari"/>
                          <TextField fx:id="searchAdjustmentField" promptText="No mutasi / alasan / user" prefWidth="220"/>
                          <Button text="Export PDF" onAction="#handleExportMutationPdf" styleClass="danger-button"/>
                          <Button text="Export Excel" onAction="#handleExportMutationExcel" styleClass="success-button"/>
                      </HBox>
                      <VBox fx:id="adjustmentHistoryContainer" VBox.vgrow="ALWAYS" spacing="0">
                          <TableView fx:id="tableAdjustmentHistory" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                             <columns>
                                <TableColumn fx:id="colAdjNo" text="No. Mutasi" prefWidth="140"/>
                                 <TableColumn fx:id="colAdjDate" text="Tanggal" prefWidth="140"/>
                                 <TableColumn fx:id="colAdjReason" text="Alasan" prefWidth="200"/>
                                 <TableColumn fx:id="colAdjUser" text="Oleh" prefWidth="100"/>
                                 <TableColumn fx:id="colAdjAction" text="Aksi" prefWidth="90"/>
                             </columns>
                             <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                             <placeholder>
                                 <Label text="Tidak ada data"/>
                             </placeholder>
                          </TableView>
                      </VBox>
                  </VBox>
               </Tab>
             </TabPane>
            </VBox>
        </Tab>
        
        <!-- NEW RETURN TAB -->
        <Tab text="Retur Baru">
            <VBox spacing="16" style="-fx-padding: 16;">
                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <Label text="Cari No. Invoice:" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtSearchInvoice" promptText="Contoh: INV-..." prefWidth="250"/>
                    <Button text="Cari" onAction="#handleSearchInvoice" styleClass="primary-button"/>
                </HBox>
                
                <TableView fx:id="tableReturn" VBox.vgrow="ALWAYS" editable="true" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <columns>
                        <TableColumn fx:id="colSku" text="SKU" prefWidth="100"/>
                        <TableColumn fx:id="colName" text="Produk" prefWidth="200"/>
                        <TableColumn fx:id="colQtySold" text="Terjual" prefWidth="80"/>
                        <TableColumn fx:id="colQtyReturned" text="Diretur" prefWidth="80"/>
                        <TableColumn fx:id="colQtyToReturn" text="Input Retur" prefWidth="100" style="-fx-alignment: CENTER-RIGHT; -fx-background-color: #f1f5f9; -fx-font-weight: bold;"/>
                    </columns>
                     <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                    <placeholder>
                        <Label text="Tidak ada data"/>
                    </placeholder>
                </TableView>
                
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button text="Batal" styleClass="secondary-button"/>
                    <Button text="Simpan Retur" onAction="#handleProcessReturn" styleClass="danger-button"/>
                </HBox>
            </VBox>
        </Tab>
        
        <!-- NEW MUTATION TAB -->
        <Tab text="Mutasi / Adjustment">
            <VBox spacing="16" style="-fx-padding: 16;">
                <HBox spacing="20">
                   <!-- Left Form -->
                   <VBox spacing="10" maxWidth="600" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 14; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8;">
                        <Label text="Formulir Penyesuaian Stok" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
                        
                        <GridPane vgap="16" hgap="12">
                             <columnConstraints>
                                <ColumnConstraints minWidth="120"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                             </columnConstraints>
                             
                             <Label text="Cari Produk" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label"/>
                             <HBox spacing="10" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                <TextField fx:id="txtSearchProduct" promptText="SKU atau Nama" HBox.hgrow="ALWAYS"/>
                                <Button text="Cek" onAction="#handleSearchProduct" styleClass="secondary-button"/>
                             </HBox>
                             
                             <Label text="Produk Terpilih" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="field-label"/>
                             <Label fx:id="lblSelectedProduct" text="-" style="-fx-font-weight: bold; -fx-text-fill: #1E40AF;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                             
                             <Label text="Adjustment" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="field-label"/>
                             <VBox spacing="4" GridPane.rowIndex="2" GridPane.columnIndex="1">
                                <TextField fx:id="txtAdjQty" promptText="Contoh: 5 atau -5"/>
                                <Label text="Positif (+) untuk tambah, Negatif (-) untuk stok hilang/rusak" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
                             </VBox>
                             
                             <Label text="Alasan" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="field-label"/>
                             <TextArea fx:id="txtAdjReason" promptText="Jelaskan alasan penyesuaian..." prefRowCount="3" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                             
                        </GridPane>
                        
                        <HBox alignment="CENTER_RIGHT" spacing="12">
                            <Button text="Simpan Mutasi" onAction="#handleProcessMutation" styleClass="warning-button"/>
                        </HBox>
                   </VBox>
                   
                   <!-- Right Info/Guide -->
                   <VBox spacing="12" prefWidth="300" style="-fx-background-color: #eff6ff; -fx-padding: 16; -fx-background-radius: 8; -fx-border-color: #bfdbfe; -fx-border-radius: 8; -fx-border-width: 1;">
                       <Label text="Panduan Mutasi" style="-fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
                       <Label text="Gunakan fitur ini untuk:" wrapText="true"/>
                       <Label text="- Stok Opname (selisih)" wrapText="true" style="-fx-padding: 0 0 0 10;"/>
                       <Label text="- Barang Rusak/Expired" wrapText="true" style="-fx-padding: 0 0 0 10;"/>
                       <Label text="- Koreksi salah input" wrapText="true" style="-fx-padding: 0 0 0 10;"/>
                       <Label text="- Bonus/Hadiah masuk" wrapText="true" style="-fx-padding: 0 0 0 10;"/>
                   </VBox>
                </HBox>
            </VBox>
        </Tab>
        
    </TabPane>
</VBox>



