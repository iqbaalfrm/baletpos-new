<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.baletpos.controller.PaymentController"
      styleClass="form-dialog" spacing="0" prefWidth="650" prefHeight="600">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" styleClass="form-dialog-header" spacing="8">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Pembayaran" style="-fx-font-size: 22px; -fx-font-weight: 700; -fx-text-fill: #0f172a;"/>
            <Label text="Pilih metode pembayaran untuk menyelesaikan transaksi" style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
        </VBox>
        <Button text="✕" onAction="#handleCancel" 
                style="-fx-background-color: transparent; -fx-font-size: 18px; -fx-text-fill: #94a3b8; -fx-cursor: hand; -fx-padding: 8;"/>
    </HBox>

    <!-- Body -->
    <VBox styleClass="form-dialog-body" spacing="10" VBox.vgrow="ALWAYS">
        
        <!-- Total Box -->
        <VBox alignment="CENTER" spacing="8" 
              style="-fx-background-color: linear-gradient(to right, #f0f9ff, #e0f2fe); -fx-padding: 16; -fx-background-radius: 16; -fx-border-color: #BFDBFE; -fx-border-radius: 16; -fx-border-width: 1.5;">
            <Label text="TOTAL TAGIHAN" style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #1E40AF; -fx-letter-spacing: 1;"/>
            <Label fx:id="grandTotalLabel" text="Rp0" style="-fx-font-size: 36px; -fx-font-weight: 800; -fx-text-fill: #1E40AF;"/>
        </VBox>
        
        <!-- Payment Methods -->
        <VBox spacing="12" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Metode Pembayaran" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #1e293b;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Tambah Metode" onAction="#handleAddMethod" 
                        style="-fx-background-color: transparent; -fx-border-color: #1E40AF; -fx-border-style: dashed; -fx-border-width: 1.5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 12px; -fx-font-weight: 600; -fx-padding: 8 16; -fx-text-fill: #1E40AF; -fx-cursor: hand;"/>
            </HBox>
            
            <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" 
                        style="-fx-background: transparent; -fx-border-color: transparent; -fx-background-color: transparent;">
                <VBox fx:id="paymentRowsBox" spacing="10" style="-fx-background-color: transparent;"/>
            </ScrollPane>
        </VBox>
        
        <Separator style="-fx-padding: 4 0;"/>
        
        <!-- Summary -->
        <VBox spacing="12" style="-fx-background-color: #f8fafc; -fx-padding: 14; -fx-background-radius: 12;">
            <HBox alignment="CENTER_LEFT">
                <Label text="Total Dibayar" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="totalPaidLabel" text="Rp0" style="-fx-font-weight: 700; -fx-font-size: 16px; -fx-text-fill: #1e293b;"/>
            </HBox>
            
            <HBox alignment="CENTER_LEFT">
                <Label text="Sisa Tagihan" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="remainingLabel" text="Rp0" style="-fx-text-fill: #dc2626; -fx-font-weight: 700; -fx-font-size: 16px;"/>
            </HBox>
            
            <Separator/>
            
            <HBox alignment="CENTER_LEFT">
                <Label text="Kembalian" style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #1e293b;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="changeLabel" text="Rp0" style="-fx-text-fill: #1E40AF; -fx-font-weight: 800; -fx-font-size: 22px;"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- Footer -->
    <HBox styleClass="form-dialog-footer" alignment="CENTER_RIGHT" spacing="8">
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Batal" onAction="#handleCancel" 
                style="-fx-background-color: white; -fx-text-fill: #475569; -fx-font-size: 14px; -fx-font-weight: 600; -fx-padding: 14 28; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e2e8f0; -fx-border-width: 1.5; -fx-cursor: hand;"/>
        <Button fx:id="payButton" text="Bayar &amp; Cetak Struk" onAction="#handlePay" disable="true"
                style="-fx-background-color: linear-gradient(to bottom, #1E40AF, #1F3A8A); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 700; -fx-padding: 14 36; -fx-background-radius: 12; -fx-border-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(5, 150, 105, 0.35), 8, 0, 0, 3);"/>
    </HBox>
</VBox>



